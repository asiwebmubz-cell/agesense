# ─── Server Configuration ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── CORS (Allowed Origins) ───────────────────────────────────────────────────
# URL of your frontend application
FRONTEND_URL=http://localhost:3000

# ─── Auth Secrets ─────────────────────────────────────────────────────────────
# Minimum 16 characters. Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_minimum_16_characters_long

# Initial Administrator Credentials
ADMIN_EMAIL=admin@agesense.org
ADMIN_PASSWORD=your_admin_password_here

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Connection string: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# ─── Image Uploads (ImgBB) ────────────────────────────────────────────────────
# Obtain from: https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_api_key_here

# ─── Render Deployment (Optional) ────────────────────────────────────────────
# Set automatically by Render (e.g. https://your-service.onrender.com)
RENDER_EXTERNAL_URL=
